{
  "name": "pxl",
  "version": "0.0.1",
  "main": "dist-electron/main/index.js",
  "description": "A desktop pixel art editor.",
  "author": "sharvenp",
  "license": "MIT",
  "private": true,
  "keywords": [
    "electron",
    "rollup",
    "vite",
    "vue3",
    "vue"
  ],
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:8080/"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "electron:build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint --ext .ts,.tsx,.vue src/",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@panzoom/panzoom": "^4.6.2",
    "autoprefixer": "^10.4.27",
    "cbor2": "^1.12.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-window-state": "^5.0.3",
    "jszip": "^3.10.1",
    "pixi.js": "^8.17.1",
    "postcss": "^8.5.8",
    "pureimage": "^0.4.18",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.19",
    "tiny-emitter": "^2.1.0",
    "tree-kill": "^1.2.2",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue": "^3.3.4",
    "vue-accessible-color-picker": "^5.3.1",
    "vue-draggable-next": "^2.3.0",
    "vue-tsc": "^2.2.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "baseline-browser-mapping": "^2.10.14",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1"
  }
}